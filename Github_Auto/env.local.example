SEA_LION_API_KEY_SISWA=ask_team_lead

# YOUR OWN GitHub Personal Access Token
# Get from: github.com → Settings → Developer settings
# → Personal access tokens → Classic → scope: repo
GITHUB_TOKEN=your_own_token_here

# Repo owner and name are now AUTO-DETECTED from git remote
# Only fill these in as fallback if auto-detect fails
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

DEFAULT_BRANCH=main
DEFAULT_REVIEWER=RiFtNaWx
# Gemma 9B — faster; if API errors, revert to Qwen 27B below
SEA_LION_MODEL=aisingapore/gemma-SEA-LION-v4.5-9b-it
# SEA_LION_MODEL=aisingapore/Qwen-SEA-LION-v4.5-27B-IT
